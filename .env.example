# Elektron Net node running in your private network 192.168.1.0/24
ELEKTRON_RPC_URL=http://192.168.1.100

# Elektron Net node running undockered on the same PC
# needs to add rpcallowip=172.16.0.0/12 to your elektron.conf
#ELEKTRON_RPC_URL=http://host.docker.internal

ELEKTRON_RPC_USER=
ELEKTRON_RPC_PASSWORD=
ELEKTRON_RPC_PORT=8332
ELEKTRON_RPC_TIMEOUT=10000

# You can use this instead of ELEKTRON_RPC_USER and ELEKTRON_RPC_PASSWORD
ELEKTRON_RPC_COOKIEFILE=

# Enable in elektron.conf with
# zmqpubrawblock=tcp://*:3000
# ELEKTRON_ZMQ_HOST="tcp://192.168.1.100:3000"

API_PORT=3334
STRATUM_PORT=3333
STRATUM_MAX_CONNECTIONS_PER_LISTENER=10000

#optional telegram bot
#TELEGRAM_BOT_TOKEN=

#optional discord bot
#DISCORD_BOT_CLIENTID=
#DISCORD_BOT_GUILD_ID=
#DISCORD_BOT_CHANNEL_ID=

#optional
DEV_FEE_ADDRESS=
# Elektron Net: mainnet | regtest
# Bitcoin compat (for upstream testing only): bitcoin-mainnet | bitcoin-testnet | bitcoin-regtest
NETWORK=mainnet

API_SECURE=false
# Default is "Public-Pool", you can change it to any string it will be removed if it will make the block or coinbase script too big
POOL_IDENTIFIER="Elektron-Pool"

# Hobby-miner compatibility: comma-separated userAgent substrings (case-insensitive).
# Matching miners get a low starting difficulty so a few-kH/s ESP32 device
# actually submits shares before the pool's dead-client timeout fires. The pool
# already runs header-only mining (EXTRANONCE2_SIZE_BYTES = 0), so no special
# wire format is needed; only the difficulty is tuned for these devices.
HOBBY_MINER_USER_AGENTS=NerdMiner,NerdminerV2,nerdminer,Bitaxe,NerdAxe,NerdQAxe,ESP-Miner
HOBBY_MINER_DIFFICULTY=0.001
